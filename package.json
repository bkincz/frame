{
  "name": "@bkincz/frame",
  "version": "1.1.0",
  "description": "A production-ready, TypeScript-first React multi-step flow system with animations, navigation history, and customizable layouts",
  "type": "module",
  "main": "./dist/frame.cjs",
  "module": "./dist/frame.mjs",
  "types": "./dist/frame.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/frame.d.mts",
        "default": "./dist/frame.mjs"
      },
      "require": {
        "types": "./dist/frame.d.cts",
        "default": "./dist/frame.cjs"
      }
    },
    "./styles": "./dist/frame.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "keywords": [
    "react",
    "components",
    "flow",
    "wizard",
    "multi-step",
    "stepper",
    "forms",
    "ui",
    "nextjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bkincz/frame.git"
  },
  "bugs": {
    "url": "https://github.com/bkincz/frame/issues"
  },
  "homepage": "https://github.com/bkincz/frame#readme",
  "author": "Benjamin Kinczel <beni.kinczel@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build:lib",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "peerDependencies": {
    "@bkincz/clutch": "^1.0.3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "gsap": "^3.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sass": "^1.97.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  }
}
